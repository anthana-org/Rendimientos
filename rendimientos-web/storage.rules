rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Reglas para archivos de contratos
    match /contracts/{userId}/{allPaths=**} {
      // Permitir lectura si el usuario es admin o es el dueño del archivo
      allow read: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.uid == userId ||
        request.auth.token.email == "admin@test.com"
      );
      
      // Permitir escritura solo a admins
      allow write: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.email == "admin@test.com"
      );
      
      // Validar tamaño del archivo (máximo 10MB)
      allow create: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
  }
}


